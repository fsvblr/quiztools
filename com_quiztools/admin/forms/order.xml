<?xml version="1.0" encoding="UTF-8"?>
<form addfieldprefix="Qt\Component\Quiztools\Administrator\Field">
    <fieldset name="order">
        <field
            name="id"
            type="text"
            label="JGLOBAL_FIELD_ID_LABEL"
            default="0"
            readonly="true"
            class="readonly"
        />

        <field
            name="status"
            type="list"
            label="COM_QUIZTOOLS_ORDER_FIELD_STATUS_LABEL"
            class="form-select"
            default=""
            required="true"
        >
            <option value="">COM_QUIZTOOLS_ORDER_FIELD_STATUS_OPTION_SELECT</option>
            <option value="P">COM_QUIZTOOLS_ORDER_FIELD_STATUS_OPTION_PENDING</option>
            <option value="C">COM_QUIZTOOLS_ORDER_FIELD_STATUS_OPTION_CONFIRMED</option>
        </field>

        <field
            name="user_id"
            type="user"
            label="COM_QUIZTOOLS_ORDER_FIELD_USER_ID_LABEL"
            validate="UserId"
            required="true"
        />

        <field
            name="subscription_id"
            type="subscriptionslist"
            label="COM_QUIZTOOLS_ORDER_FIELD_SUBSCRIPTION_ID_LABEL"
            default=""
            class="form-select"
            paymentMethod="manual"
            required="true"
        >
            <option value="">COM_QUIZTOOLS_ORDER_FIELD_SUBSCRIPTION_ID_OPTION_SELECT</option>
        </field>

        <field
            name="users_used"
            type="hidden"
            default=""
        />

        <field
            name="start_datetime"
            type="hidden"
            default=""
        />

        <field
            name="end_datetime"
            type="hidden"
            default=""
        />

        <field
            name="attempts_max"
            type="hidden"
            default=""
        />

        <field
            name="store_type"
            type="hidden"
            default="manual"
        />

        <field
            name="store_order_id"
            type="hidden"
            default="0"
        />

        <field
            name="store_product_id"
            type="hidden"
            default="0"
        />
    </fieldset>

    <fieldset name="publish">
        <field
            name="asset_id"
            type="hidden"
            filter="unset"
        />

        <field
            name="created"
            type="calendar"
            label="COM_QUIZTOOLS_ORDER_FIELD_CREATED_LABEL"
            translateformat="true"
            showtime="true"
            filter="user_utc"
        />

        <field
            name="created_by"
            type="user"
            label="COM_QUIZTOOLS_ORDER_FIELD_CREATED_BY_LABEL"
            validate="UserId"
        />

        <field
            name="modified"
            type="calendar"
            label="JGLOBAL_FIELD_MODIFIED_LABEL"
            class="readonly"
            readonly="true"
            translateformat="true"
            showtime="true"
            filter="user_utc"
        />

        <field
            name="modified_by"
            type="user"
            label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
            class="readonly"
            readonly="true"
            filter="unset"
            validate="UserId"
        />

        <field
            name="checked_out"
            type="hidden"
            filter="unset"
        />

        <field
            name="checked_out_time"
            type="hidden"
            filter="unset"
        />
    </fieldset>
</form>
